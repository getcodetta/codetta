{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codetta",
  "version": "0.3.2",
  "identifier": "dev.getcodetta.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codetta",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "resizable": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Codetta",
    "copyright": "Copyright © 2026 Codetta Maintainers",
    "category": "DeveloperTool",
    "shortDescription": "A lightweight desktop code editor with first-class AI.",
    "longDescription": "Codetta is a lightweight desktop code editor built on Tauri. Bring your own AI model — Anthropic Claude, OpenAI, Ollama, or Claude Code — and edit with multi-pane splits, integrated git, multi-terminal support (with pop-out windows), and per-project workspaces.",
    "homepage": "https://codetta.dev",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "languages": ["English"],
        "compression": "lzma",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "Codetta"
      }
    }
  }
}
